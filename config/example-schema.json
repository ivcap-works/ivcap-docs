{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "slug",
      "name",
      "repo",
      "branch",
      "capabilities",
      "sdks",
      "difficulty",
      "pull_files"
    ],
    "additionalProperties": true,
    "properties": {
      "slug": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "repo": {
        "type": "string",
        "pattern": "^[^/]+/[^/]+$"
      },
      "branch": {
        "type": "string"
      },
      "capabilities": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "run-services",
            "build-services",
            "artifacts",
            "aspects",
            "data-fabric",
            "workflows",
            "queues",
            "ai-agents",
            "domain-bio"
          ]
        }
      },
      "sdks": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "difficulty": {
        "type": "string",
        "enum": [
          "beginner",
          "intermediate",
          "advanced"
        ]
      },
      "pull_files": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}